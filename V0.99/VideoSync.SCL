configuration for "dsPIC33FJ64GP204" is
    constant Minus1ns : time := 18446744073709551615 ns;	
--SCL uses 64 bit integer math for everything, thus -1ns = h'FFFFFFFFFFFFFFFF'
-- = 18446744073709551615 decimal.
    constant ComparatorDelay : time := 300 ns;
    constant StartLine : integer := 50;					
    constant StartDelay : time := 22 us;
    constant TLine : time := 64 us;
    constant THLine : time :=  32 us;
    constant TSync : time := 4.75 us;
    constant TEgPulse : time := 2 us;
    constant TMaxPosLineError : integer := 0;  -- us
    constant TMaxNegLineError : integer := 0; --us ..If negative put -const SCL does not handle negate of constant in runtime.
    constant TLinePosJitter : integer := 1000; -- ns 
    constant TLineNegJitter : integer := -1000; -- ns .. SCL does not handle -constant

    --Calcs for 56pF / 22K RC filter on RB4, driven from RB3
    constant Vcc : integer   := 3300000;    -- 3V3 = 3.3e6 uV 
    constant Vhigh : integer := 2640000;    -- 0.8 Vcc
    constant Vlow  : integer :=  660000;    -- 0.2 Vcc
    
    constant ExpT	: integer := 3333;		-- (Vcc/1e3)/(1-exp(-t/T)) where t = Dt step size (250n), 
                                            --  T = RC time constant.
    constant ExpT2 : integer := 1667; 		-- ExpT /2
end configuration;


testbench for "dsPIC33FJ64GP204" is
begin

    -- RB0  - sync_in (video)    C2In-  (RB0)
 	-- RB12 - sync_sep           C2Out  (RB12)
    -- RB1  - sync_slice         C2In+  (RA2)
    
    INIT: process is
    begin
        RB1 <= '0';	-- Sync Slice	
        RB0 <= '1'; -- Sync_in
        wait;
    end process;

    -- Load A-D
    process is
    begin
        accessin("SIMULATOR_AD_VALUE.TXT", hex_mode, ADC1BUF0, true);
    print("A-D loaded");
        wait;
    end process;

//    COMP2: process is
