//                SPI_Data := SPI1BUF;
//                wait for 2 us;
//            end if;
            
            wait for 1 ic;
            
        end loop;
        
            wait for 1 ic;
    end process;        
    
	SPI_GET: process is
      	file SPI_File : text;
		variable SPI_file_status : file_open_status;
        variable SPI_Int : integer;       
		variable SPI_L : line;
        variable SPI_FileOpen : boolean := false;
        variable SPI_Start : time := 0 us;
        variable SPI_Temp : integer;
        -- Loop counters
        variable SPI_I : integer;
        variable SPI_J : integer;
	begin
		if SPI_Run == true then
			SPI_Start := now();
	        if SPI_FileOpen /= true then
			    file_open(SPI_file_status, SPI_File, "null", read_mode);
	            if SPI_file_status == open_ok then
	            wait for 1 ic;
	            
	            SPI_FileOpen := true;
	            end if;
	        end if;
	
	         if SPI_file_status == open_ok then
				while endfile(SPI_File) == false loop
	    			readline(SPI_File, SPI_L);
	    			read(SPI_L, SPI_Int);				
print(">>>",SPI_Int);
//					SPI1BUF <= SPI_Int;
//					SPI1STAT.SPIRBF <= '1';
//					IFS0.SPI1IF <= '1';					
//					wait for 1 ic;
//					IFS0.SPI1IF <= '0';
//					SPI1STAT.SPIRBF <= '0';
				end loop;
				RP8 <= '1';
			end if;
	
			-- Set the Rx full flag.
	 //		SPI1STAT.SPIRBF <= '1';
			//file_close(SPI_File);
			//SPI_FileOpen := false;
      		
	

		end if;
        wait for 1 ic;
	end process SPI_GET;
    
//    -- Simulate RC filter from RB3 to RB4
//    SYNC_FILTER: process is
//        variable Vc : integer := 0;
//        variable Dv : integer := 0;
//        variable VI : integer := 0;
//    begin
//        if RB3 == '1'  then
//            VI := Vcc;
//        else
//            VI := 0;
//        end if;
//        Dv := VI - Vc;
//        Dv := (Dv*100);
//        Dv := Dv + ExpT2;
//        Dv := Dv / ExpT;
//        Dv := Dv * 10;
//        Vc := Vc + Dv;
//        if Vc >= Vhigh then
//            RB4 <= '1';
//        end if;
//        if Vc <= Vlow then
//            RB4 <= '0';
//        end if;
//        wait for 250 ns;
//    end process;
    
    LINE_STATE_MACHINE: process is
        variable LineError : time := 0;
        variable LineTime : time;
        variable LineCntr : integer;
        variable Tm : time := 0;
    begin
        wait for 1 ic;
        wait for StartDelay;
        LineCntr := StartLine;
        while true loop   
            while LineCntr < 5 loop		--Even Field pulses
                RB0 <= '0';
                RB1 <= '1';
                wait for (THLine - TSync);
                RB0 <= '1';
                RB1 <= '0';
                wait for TSync;
                LineCntr := LineCntr + 1;
            end loop;

            while LineCntr < 10 loop	--Even field start equalisation
                RB0 <= '0';
                RB1 <= '1';
                wait for TEgPulse;
                RB0 <= '1';
                RB1 <= '0';
                wait for (THLine - TEgPulse);
                LineCntr := LineCntr + 1;
            end loop;

            while LineCntr < 620 loop	--Even Lines
                RB0 <= '0';
                RB1 <= '1';
                wait for TSync;
                RB0 <= '1';
                RB1 <= '0';
                wait for (TLine - TSync);
                LineCntr := LineCntr + 2;
            end loop;

            while LineCntr < 625 loop	--Even field end equalisation
                RB0 <= '0';
                RB1 <= '1';
                wait for TEgPulse;
                RB0 <= '1';
                RB1 <= '0';
                wait for (THLine - TEgPulse);
                LineCntr := LineCntr + 1;
            end loop;

            while LineCntr < 630 loop	--Odd field sync
                RB0 <= '0';
                RB1 <= '1';
                wait for (THLine - TSync);
                RB0 <= '1';
                RB1 <= '0';
                wait for TSync;
                LineCntr := LineCntr + 1;
            end loop;

            while LineCntr < 634 loop	--Odd field start equalisation
                RB0 <= '0';
                RB1 <= '1';
                wait for TEgPulse;
                RB0 <= '1';
                RB1 <= '0';
                wait for (THLine - TEgPulse);
                LineCntr := LineCntr + 1;
            end loop;
            

            while LineCntr < 1244 loop  --Odd Lines
                RB0 <= '0';
                RB1 <= '1';
                wait for TSync;
                RB0 <= '1';
                RB1 <= '0';
                wait for (THLine - TSync);
                LineCntr := LineCntr + 1;
                if LineCntr < 1244 then
                    wait for (THLine);
                end if;
                LineCntr := LineCntr +1;
            end loop;

            while LineCntr < 1250 loop
                RB0 <= '0';
                RB1 <= '1';
                wait for TEgPulse;
                RB0 <= '1';
                RB1 <= '0';
                wait for (THLine - TEgPulse);
                LineCntr := LineCntr + 1;
            end loop;

            LineCntr := 0;
        end loop;
    end process;

end testbench;

