//        RC2 <= '1';
//    end process;
    
    // Register Trace
    process is
    begin
        accessout("null", hex_mode, SPI1BUF);
        wait;
    end process;

    SPI_RUN_TEST: process is
        variable SPI_Run : boolean := false;
    begin
    	print("Start");
    	loop
	    	wait until SPI1STAT.SPIEN == '1';
	    	print("SPI started");
			SPI_Run := true;
			wait until SPI1STAT.SPIEN == '0';
			SPI_Run := false;
			print ("SPI stopped");
		end loop;
    end process;
       

    SPI_TX: process is
        variable SPI_Data : integer;
    begin
         loop
            exit when SPI_Run == false;
  
---- DOES NOT WORK dsPIC            
